{
    "id": "landuse-pitch",
    "type": "fill",
    "source": "openmaptiles",
    "source-layer": "landuse",
    "minzoom": 7,
    "layout": {
        "visibility": "visible"
    },
    "paint": {
        "fill-color": "hsl(157, 47%, 80%)",
        "fill-opacity": 1
    },
    "metadata": {},
    "filter": [
        "all",
        [
            "in",
            "class",
            "pitch",
            "track"
        ],
        [
            "==",
            "$type",
            "Polygon"
        ]
    ]
}