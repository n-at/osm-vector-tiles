{
    "id": "poi-local-park",
    "type": "symbol",
    "source": "openmaptiles",
    "source-layer": "poi",
    "minzoom": 15,
    "layout": {
        "symbol-sort-key": [
            "to-number",
            [
                "get",
                "rank"
            ]
        ],
        "symbol-spacing": 150,
        "text-allow-overlap": false,
        "text-field": [
            "coalesce",
            [
                "get",
                "name:ru"
            ],
            [
                "get",
                "name:en"
            ],
            [
                "get",
                "name:nonlatin"
            ],
            [
                "get",
                "name:latin"
            ],
            [
                "get",
                "name"
            ]
        ],
        "text-font": [
            "Open Sans Semibold Italic",
            "Noto Sans Italic"
        ],
        "text-max-width": {
            "stops": [
                [
                    12,
                    5
                ],
                [
                    18,
                    8
                ]
            ]
        },
        "text-size": {
            "stops": [
                [
                    15,
                    10
                ],
                [
                    20,
                    13
                ]
            ]
        },
        "visibility": "visible"
    },
    "paint": {
        "text-color": "hsl(125, 83%, 28%)",
        "text-halo-blur": 0.5,
        "text-halo-color": "hsl(0, 0%, 100%)",
        "text-halo-width": 1
    },
    "filter": [
        "all",
        [
            "==",
            "class",
            "park"
        ],
        [
            "==",
            "subclass",
            "park"
        ]
    ]
}