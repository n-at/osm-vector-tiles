{
    "id": "poi-outdoor",
    "type": "symbol",
    "source": "openmaptiles",
    "source-layer": "poi",
    "minzoom": 16,
    "layout": {
        "icon-allow-overlap": false,
        "icon-image": "{subclass}",
        "symbol-sort-key": [
            "to-number",
            [
                "get",
                "rank"
            ]
        ],
        "text-anchor": "top",
        "text-field": [
            "coalesce",
            [
                "get",
                "name:ru"
            ],
            [
                "get",
                "name:en"
            ],
            [
                "get",
                "name:nonlatin"
            ],
            [
                "get",
                "name:latin"
            ],
            [
                "get",
                "name"
            ]
        ],
        "text-font": [
            "Open Sans Semibold Italic",
            "Noto Sans Bold"
        ],
        "text-max-width": 9,
        "text-offset": [
            0,
            1.2
        ],
        "text-padding": 2,
        "text-size": {
            "stops": [
                [
                    15,
                    10
                ],
                [
                    20,
                    11
                ]
            ]
        },
        "visibility": "visible"
    },
    "paint": {
        "icon-halo-blur": 0,
        "icon-opacity": 1,
        "text-color": "hsl(126, 100%, 27%)",
        "text-halo-blur": 1,
        "text-halo-color": "hsl(0, 0%, 100%)",
        "text-halo-width": 0.2
    },
    "metadata": [],
    "filter": [
        "all",
        [
            "in",
            "class",
            "pitch",
            "playground",
            "stile",
            "garden",
            "gate"
        ]
    ]
}